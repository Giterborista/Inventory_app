# Server-side only. Never prefix this variable with NEXT_PUBLIC_.
OPENAI_API_KEY=

# Optional. Use a model available to your OpenAI API project.
OPENAI_MODEL=gpt-5.4-mini

# Local development stays open. On Render, set this to true and add the two
# secrets produced by `npm run auth:generate` in the Render Environment panel.
AI_AUTH_ENABLED=false
AI_AUTH_PASSWORD_HASH=
AI_AUTH_SESSION_SECRET=
